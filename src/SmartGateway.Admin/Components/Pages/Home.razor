@page "/"
@using Microsoft.EntityFrameworkCore
@using SmartGateway.Core.Data
@using SmartGateway.Core.Entities
@inject IDbContextFactory<SmartGatewayDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Dashboard - SmartGateway</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Control plane overview — live YARP state</div>
    </div>
    <div style="margin-left:auto;display:flex;gap:8px">
        <a href="clusters" class="btn btn-ghost btn-sm">Clusters</a>
        <a href="routes" class="btn btn-primary btn-sm">+ New Route</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Active clusters</div>
        <div class="stat-val">@_activeClusterCount<span class="stat-unit">/@_clusterCount</span></div>
        <div class="stat-bar"><div class="stat-fill" style="width:@(_clusterCount > 0 ? (int)((double)_activeClusterCount/_clusterCount*100) : 0)%;background:var(--accent)"></div></div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Active routes</div>
        <div class="stat-val">@_activeRouteCount<span class="stat-unit">/@_routeCount</span></div>
        <div class="stat-bar"><div class="stat-fill" style="width:@(_routeCount > 0 ? (int)((double)_activeRouteCount/_routeCount*100) : 0)%;background:var(--accent2)"></div></div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Healthy nodes</div>
        <div class="stat-val">@_healthyCount<span class="stat-unit">/@_destinationCount</span></div>
        <div class="stat-bar"><div class="stat-fill" style="width:@(_destinationCount > 0 ? (int)((double)_healthyCount/_destinationCount*100) : 0)%;background:var(--success)"></div></div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Unhealthy</div>
        <div class="stat-val" style="color:@(_unhealthyCount > 0 ? "var(--danger)" : "var(--success)")">@_unhealthyCount</div>
        @if (_unhealthyCount > 0)
        {
            <div class="stat-delta down">@_unhealthyCount node(s) evicted</div>
        }
        else
        {
            <div class="stat-delta up">All systems operational</div>
        }
    </div>
</div>

<div class="grid-2">
    <div class="card">
        <div class="card-header">
            <div class="card-title">Recent clusters</div>
            <span class="badge badge-gray">@_clusterCount total</span>
        </div>
        @if (_recentClusters != null && _recentClusters.Count > 0)
        {
            @foreach (var c in _recentClusters)
            {
                <div class="dest-row">
                    <div class="dest-indicator" style="background:@(c.IsActive ? "var(--success)" : "var(--danger)")"></div>
                    <div class="dest-addr" style="color:var(--text);font-weight:500">@c.ClusterId</div>
                    <span class="badge badge-gray">@c.LoadBalancing</span>
                    @if (c.IsActive)
                    {
                        <span class="badge badge-green" style="font-size:10px"><span class="badge-dot"></span>active</span>
                    }
                    else
                    {
                        <span class="badge badge-red" style="font-size:10px"><span class="badge-dot"></span>inactive</span>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-title">No clusters yet</div>
                <div class="empty-desc">Create your first upstream cluster.</div>
            </div>
        }
    </div>
    <div class="card">
        <div class="card-header">
            <div class="card-title">Recent routes</div>
            <span class="badge badge-gray">@_routeCount total</span>
        </div>
        @if (_recentRoutes != null && _recentRoutes.Count > 0)
        {
            @foreach (var r in _recentRoutes)
            {
                <div class="dest-row">
                    <div class="dest-indicator" style="background:@(r.IsActive ? "var(--success)" : "var(--danger)")"></div>
                    <div style="flex:1">
                        <span class="tag">@r.RouteId</span>
                    </div>
                    <span style="font-family:var(--mono);font-size:11px;color:var(--text3)">@r.PathPattern</span>
                    <span class="badge badge-gray" style="font-size:10px">@r.ClusterId</span>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <div class="empty-title">No routes yet</div>
                <div class="empty-desc">Create a route to start proxying traffic.</div>
            </div>
        }
    </div>
</div>

@code {
    private int _clusterCount, _activeClusterCount, _routeCount, _activeRouteCount;
    private int _destinationCount, _healthyCount, _unhealthyCount;
    private List<GatewayCluster>? _recentClusters;
    private List<GatewayRoute>? _recentRoutes;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        _clusterCount = await context.Clusters.CountAsync();
        _activeClusterCount = await context.Clusters.CountAsync(c => c.IsActive);
        _routeCount = await context.Routes.CountAsync();
        _activeRouteCount = await context.Routes.CountAsync(r => r.IsActive);
        _destinationCount = await context.Destinations.CountAsync();
        _healthyCount = await context.Destinations.CountAsync(d => d.IsHealthy);
        _unhealthyCount = _destinationCount - _healthyCount;
        _recentClusters = await context.Clusters.AsNoTracking().OrderByDescending(c => c.UpdatedAt).Take(5).ToListAsync();
        _recentRoutes = await context.Routes.AsNoTracking().OrderByDescending(r => r.UpdatedAt).Take(5).ToListAsync();
    }
}
