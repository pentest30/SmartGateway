@page "/destinations"
@using Microsoft.EntityFrameworkCore
@using SmartGateway.Core.Data
@using SmartGateway.Core.Entities
@inject IDbContextFactory<SmartGatewayDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Destinations - SmartGateway</PageTitle>

<div class="page-header">
    <div>
        <div class="page-title">Destinations</div>
        <div class="page-sub">Upstream service instances per cluster</div>
    </div>
    <div style="margin-left:auto">
        <button class="btn btn-primary" @onclick="() => _showModal = true">+ Add Destination</button>
    </div>
</div>

<div class="section-full">
    <div class="section-head">
        <div class="card-title">All destinations</div>
        <span class="badge badge-gray">@(_destinations?.Count ?? 0) total</span>
        @if (_destinations != null)
        {
            var healthy = _destinations.Count(d => d.IsHealthy);
            <span class="badge badge-green">@healthy healthy</span>
            var unhealthy = _destinations.Count - healthy;
            @if (unhealthy > 0)
            {
                <span class="badge badge-red">@unhealthy unhealthy</span>
            }
        }
    </div>
    @if (_destinations == null)
    {
        <div style="padding:24px;color:var(--text3)">Loading...</div>
    }
    else if (_destinations.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-title">No destinations registered</div>
            <div class="empty-desc">Add upstream service instances to a cluster.</div>
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Destination</th>
                    <th>Cluster</th>
                    <th>Address</th>
                    <th>Weight</th>
                    <th>Health</th>
                    <th>Last heartbeat</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dest in _destinations)
                {
                    <tr>
                        <td><span class="tag">@dest.DestinationId</span></td>
                        <td>@dest.ClusterId</td>
                        <td><span style="font-family:var(--mono);font-size:12px;color:var(--text)">@dest.Address</span></td>
                        <td><span style="font-family:var(--mono);font-size:12px;color:var(--text3)">@dest.Weight</span></td>
                        <td>
                            @if (dest.IsHealthy)
                            {
                                <span class="badge badge-green"><span class="badge-dot"></span>healthy</span>
                            }
                            else
                            {
                                <span class="badge badge-red"><span class="badge-dot"></span>evicted</span>
                            }
                        </td>
                        <td><span style="font-family:var(--mono);font-size:11px;color:var(--text3)">@(dest.LastHeartbeat?.ToString("HH:mm:ss") ?? "—")</span></td>
                        <td>
                            <div style="display:flex;gap:4px">
                                @if (dest.IsHealthy)
                                {
                                    <button class="btn btn-ghost btn-sm" @onclick="() => ToggleHealth(dest.Id, false)">Evict</button>
                                }
                                else
                                {
                                    <button class="btn btn-primary btn-sm" @onclick="() => ToggleHealth(dest.Id, true)">Re-admit</button>
                                }
                                <button class="btn btn-danger btn-sm" @onclick="() => DeleteDestination(dest.Id)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (_showModal)
{
    <div class="modal-overlay open" @onclick="OnOverlayClick">
        <div class="modal" @onclick:stopPropagation="true">
            <div class="modal-title">Add Destination</div>
            <div class="form-row">
                <div class="form-group">
                    <div class="form-label">Cluster</div>
                    <select @bind="_newClusterId" class="form-select">
                        @foreach (var c in _clusterIds)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <div class="form-label">Destination ID</div>
                    <input @bind="_newDestId" class="form-input" placeholder="e.g. instance-1" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <div class="form-label">Address</div>
                    <input @bind="_newAddress" class="form-input" placeholder="10.0.1.10:8080" />
                </div>
                <div class="form-group">
                    <div class="form-label">Weight</div>
                    <input @bind="_newWeight" type="number" class="form-input" />
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn btn-ghost" @onclick="() => _showModal = false">Cancel</button>
                <button class="btn btn-primary" @onclick="AddDestination">Register destination</button>
            </div>
        </div>
    </div>
}

@code {
    private List<GatewayDestination>? _destinations;
    private List<string> _clusterIds = new();
    private bool _showModal;
    private string _newClusterId = "", _newDestId = "", _newAddress = "";
    private int _newWeight = 100;

    protected override async Task OnInitializedAsync() => await LoadData();

    private void OnOverlayClick() => _showModal = false;

    private async Task LoadData()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        _destinations = await context.Destinations.AsNoTracking().OrderBy(d => d.ClusterId).ThenBy(d => d.DestinationId).ToListAsync();
        _clusterIds = await context.Clusters.AsNoTracking().Select(c => c.ClusterId).OrderBy(c => c).ToListAsync();
        if (_clusterIds.Count > 0 && string.IsNullOrEmpty(_newClusterId)) _newClusterId = _clusterIds[0];
    }

    private async Task AddDestination()
    {
        if (string.IsNullOrWhiteSpace(_newDestId) || string.IsNullOrWhiteSpace(_newAddress)) return;
        using var context = await DbFactory.CreateDbContextAsync();
        context.Destinations.Add(new GatewayDestination { ClusterId = _newClusterId, DestinationId = _newDestId.Trim(), Address = _newAddress.Trim(), Weight = _newWeight });
        await context.SaveChangesAsync();
        _newDestId = ""; _newAddress = ""; _newWeight = 100;
        _showModal = false;
        await LoadData();
    }

    private async Task ToggleHealth(int id, bool healthy)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var d = await context.Destinations.FindAsync(id);
        if (d != null) { d.IsHealthy = healthy; await context.SaveChangesAsync(); }
        await LoadData();
    }

    private async Task DeleteDestination(int id)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var d = await context.Destinations.FindAsync(id);
        if (d != null) { context.Destinations.Remove(d); await context.SaveChangesAsync(); }
        await LoadData();
    }
}
