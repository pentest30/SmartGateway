@inherits LayoutComponentBase
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable

<div class="layout">
    <div class="topbar">
        <div class="logo">
            <div class="logo-mark">
                <svg viewBox="0 0 16 16" fill="none" stroke="#0a1a14" stroke-width="2" stroke-linecap="round">
                    <path d="M2 8h3M11 8h3M8 2v3M8 11v3"/>
                    <circle cx="8" cy="8" r="2.5" fill="#0a1a14" stroke="none"/>
                </svg>
            </div>
            Smart<span>Gateway</span>
        </div>
        <div style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-left:8px">v1.0.0</div>
        <div class="topbar-right">
            @if (_hostOnline)
            {
                <div class="reload-badge"><div class="reload-dot"></div>YARP live</div>
            }
            <div class="avatar">SG</div>
        </div>
    </div>

    <div class="sidebar">
        <NavMenu />
    </div>

    <div class="main">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _hostOnline;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(async _ =>
        {
            _hostOnline = await CheckHostAlive();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task<bool> CheckHostAlive()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("GatewayHost");
            var response = await client.GetAsync("/");
            return true;
        }
        catch
        {
            return false;
        }
    }

    public void Dispose() => _timer?.Dispose();
}
